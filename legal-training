<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>法务助理培训管理系统</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Noto Sans SC', sans-serif; background: #f1f5f9; }
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .card-hover {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .card-hover:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        .progress-ring { transform: rotate(-90deg); }
        .progress-ring-circle { transition: stroke-dashoffset 0.5s ease-in-out; }
        .task-checkbox:checked + div {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border-color: #059669;
        }
        .task-checkbox:checked + div i {
            opacity: 1;
            transform: scale(1);
        }
        .slide-in {
            animation: slideIn 0.5s ease-out;
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .fade-in {
            animation: fadeIn 0.3s ease-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
    </style>
</head>
<body class="min-h-screen">

    <!-- 顶部导航 -->
    <nav class="gradient-bg text-white shadow-lg sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center space-x-4">
                    <div class="bg-white/20 p-2 rounded-lg">
                        <i class="fas fa-balance-scale text-2xl"></i>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold tracking-wide">法务助理培训管理系统</h1>
                        <p class="text-xs text-white/80">Legal Assistant Training Dashboard</p>
                    </div>
                </div>
                <div class="flex items-center space-x-6">
                    <div class="text-right hidden sm:block">
                        <p class="text-sm font-medium" id="current-date">2026年4月14日</p>
                        <p class="text-xs text-white/70">周二 第1周</p>
                    </div>
                    <button onclick="switchDate()" class="bg-white/20 hover:bg-white/30 px-4 py-2 rounded-lg transition-all flex items-center space-x-2">
                        <i class="fas fa-calendar-alt"></i>
                        <span class="hidden sm:inline">切换日期</span>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- 日期切换面板 -->
    <div id="date-panel" class="hidden fixed top-16 right-4 bg-white rounded-xl shadow-2xl p-4 z-40 w-64 border border-slate-200 fade-in">
        <h3 class="font-bold text-slate-800 mb-3">选择培训日期</h3>
        <div class="space-y-2">
            <button onclick="loadDate('2026-04-14')" class="w-full text-left px-4 py-2 rounded-lg hover:bg-blue-50 text-sm font-medium text-blue-600 bg-blue-50 border border-blue-200">
                4月14日（今日）
            </button>
            <button onclick="loadDate('2026-04-15')" class="w-full text-left px-4 py-2 rounded-lg hover:bg-slate-50 text-sm text-slate-600">
                4月15日（明日）
            </button>
            <button onclick="loadDate('2026-04-16')" class="w-full text-left px-4 py-2 rounded-lg hover:bg-slate-50 text-sm text-slate-600">
                4月16日
            </button>
        </div>
    </div>

    <!-- 主要内容区 -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- 统计概览卡片 -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8 slide-in">
            <div class="glass-panel rounded-2xl p-6 shadow-sm border-l-4 border-blue-500">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-sm text-slate-500 mb-1">今日培训任务</p>
                        <h3 class="text-3xl font-bold text-slate-800" id="total-tasks">8</h3>
                        <p class="text-xs text-blue-600 mt-2 font-medium">全部必修</p>
                    </div>
                    <div class="bg-blue-100 p-3 rounded-xl">
                        <i class="fas fa-tasks text-blue-600 text-xl"></i>
                    </div>
                </div>
            </div>
            
            <div class="glass-panel rounded-2xl p-6 shadow-sm border-l-4 border-emerald-500">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-sm text-slate-500 mb-1">平均完成进度</p>
                        <h3 class="text-3xl font-bold text-slate-800" id="avg-progress">62%</h3>
                        <p class="text-xs text-emerald-600 mt-2 font-medium">较昨日 +15%</p>
                    </div>
                    <div class="bg-emerald-100 p-3 rounded-xl">
                        <i class="fas fa-chart-line text-emerald-600 text-xl"></i>
                    </div>
                </div>
            </div>

            <div class="glass-panel rounded-2xl p-6 shadow-sm border-l-4 border-amber-500">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-sm text-slate-500 mb-1">待回课任务</p>
                        <h3 class="text-3xl font-bold text-slate-800" id="review-tasks">3</h3>
                        <p class="text-xs text-amber-600 mt-2 font-medium">明日截止</p>
                    </div>
                    <div class="bg-amber-100 p-3 rounded-xl">
                        <i class="fas fa-clipboard-check text-amber-600 text-xl"></i>
                    </div>
                </div>
            </div>

            <div class="glass-panel rounded-2xl p-6 shadow-sm border-l-4 border-purple-500">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-sm text-slate-500 mb-1">培训人员</p>
                        <h3 class="text-3xl font-bold text-slate-800">2</h3>
                        <p class="text-xs text-purple-600 mt-2 font-medium">赵柳文、曲源</p>
                    </div>
                    <div class="bg-purple-100 p-3 rounded-xl">
                        <i class="fas fa-users text-purple-600 text-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- 培训内容看板 -->
        <div class="mb-8 slide-in" style="animation-delay: 0.1s;">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-2xl font-bold text-slate-800" id="board-title">今日培训内容看板</h2>
                    <p class="text-slate-500 mt-1" id="board-subtitle">2026年4月14日 · 法务助理入职培训 Day 1</p>
                </div>
                <div class="flex space-x-2">
                    <button onclick="switchView('list')" id="btn-list" class="px-4 py-2 rounded-lg bg-white shadow-sm text-blue-600 border border-blue-200">
                        <i class="fas fa-list mr-2"></i>列表视图
                    </button>
                    <button onclick="switchView('card')" id="btn-card" class="px-4 py-2 rounded-lg bg-white shadow-sm text-slate-600 hover:bg-slate-50 transition-all">
                        <i class="fas fa-th-large mr-2"></i>卡片视图
                    </button>
                </div>
            </div>

            <!-- 培训任务列表 -->
            <div id="training-content" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- 任务内容由JS动态生成 -->
            </div>
        </div>

        <!-- 个人进度追踪 -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 slide-in" style="animation-delay: 0.2s;">
            
            <!-- 赵柳文进度 -->
            <div class="glass-panel rounded-2xl p-6 shadow-lg">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center space-x-4">
                        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-pink-400 to-rose-500 flex items-center justify-center text-white text-2xl font-bold shadow-lg">
                            赵
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-slate-800">赵柳文</h3>
                            <p class="text-sm text-slate-500">法务助理 · 入职第1天</p>
                        </div>
                    </div>
                    <div class="relative w-20 h-20">
                        <svg class="progress-ring w-20 h-20" viewBox="0 0 100 100">
                            <circle cx="50" cy="50" r="45" fill="none" stroke="#e2e8f0" stroke-width="8"/>
                            <circle id="zhao-progress" cx="50" cy="50" r="45" fill="none" stroke="url(#gradient1)" stroke-width="8" 
                                stroke-dasharray="283" stroke-dashoffset="70" stroke-linecap="round" class="progress-ring-circle"/>
                            <defs>
                                <linearGradient id="gradient1" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="0%" stop-color="#f472b6" />
                                    <stop offset="100%" stop-color="#e11d48" />
                                </linearGradient>
                            </defs>
                        </svg>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <span id="zhao-percent" class="text-lg font-bold text-slate-700">75%</span>
                        </div>
                    </div>
                </div>
                
                <div class="space-y-3">
                    <div class="flex justify-between text-sm mb-1">
                        <span class="text-slate-600">今日任务完成</span>
                        <span id="zhao-count" class="font-medium text-slate-800">6/8</span>
                    </div>
                    <div class="w-full bg-slate-200 rounded-full h-2.5">
                        <div id="zhao-bar" class="bg-gradient-to-r from-pink-400 to-rose-500 h-2.5 rounded-full transition-all duration-500" style="width: 75%"></div>
                    </div>
                    
                    <div class="mt-4 pt-4 border-t border-slate-100">
                        <h4 class="text-sm font-semibold text-slate-700 mb-3">作业提交情况</h4>
                        <div class="space-y-2" id="zhao-homework">
                            <!-- 动态生成 -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- 曲源进度 -->
            <div class="glass-panel rounded-2xl p-6 shadow-lg">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center space-x-4">
                        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-white text-2xl font-bold shadow-lg">
                            曲
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-slate-800">曲源</h3>
                            <p class="text-sm text-slate-500">法务助理 · 入职第1天</p>
                        </div>
                    </div>
                    <div class="relative w-20 h-20">
                        <svg class="progress-ring w-20 h-20" viewBox="0 0 100 100">
                            <circle cx="50" cy="50" r="45" fill="none" stroke="#e2e8f0" stroke-width="8"/>
                            <circle id="qu-progress" cx="50" cy="50" r="45" fill="none" stroke="url(#gradient2)" stroke-width="8" 
                                stroke-dasharray="283" stroke-dashoffset="140" stroke-linecap="round" class="progress-ring-circle"/>
                            <defs>
                                <linearGradient id="gradient2" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="0%" stop-color="#22d3ee" />
                                    <stop offset="100%" stop-color="#3b82f6" />
                                </linearGradient>
                            </defs>
                        </svg>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <span id="qu-percent" class="text-lg font-bold text-slate-700">50%</span>
                        </div>
                    </div>
                </div>
                
                <div class="space-y-3">
                    <div class="flex justify-between text-sm mb-1">
                        <span class="text-slate-600">今日任务完成</span>
                        <span id="qu-count" class="font-medium text-slate-800">4/8</span>
                    </div>
                    <div class="w-full bg-slate-200 rounded-full h-2.5">
                        <div id="qu-bar" class="bg-gradient-to-r from-cyan-400 to-blue-500 h-2.5 rounded-full transition-all duration-500" style="width: 50%"></div>
                    </div>
                    
                    <div class="mt-4 pt-4 border-t border-slate-100">
                        <h4 class="text-sm font-semibold text-slate-700 mb-3">作业提交情况</h4>
                        <div class="space-y-2" id="qu-homework">
                            <!-- 动态生成 -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 明日预告 -->
        <div class="mt-8 glass-panel rounded-2xl p-6 shadow-sm slide-in" style="animation-delay: 0.3s;">
            <div class="flex items-center space-x-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600">
                    <i class="fas fa-calendar-day"></i>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-800">明日培训预告 (4月15日)</h3>
                    <p class="text-sm text-slate-500">回课日与HKMS请款流程学习</p>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-indigo-50 rounded-xl p-4 border border-indigo-100">
                    <div class="flex items-center space-x-2 mb-2">
                        <i class="fas fa-redo text-indigo-500"></i>
                        <span class="font-medium text-indigo-900">回课检查</span>
                    </div>
                    <p class="text-sm text-indigo-700">合同类文件编号规则回课</p>
                </div>
                <div class="bg-indigo-50 rounded-xl p-4 border border-indigo-100">
                    <div class="flex items-center space-x-2 mb-2">
                        <i class="fas fa-chalkboard-teacher text-indigo-500"></i>
                        <span class="font-medium text-indigo-900">新授内容</span>
                    </div>
                    <p class="text-sm text-indigo-700">HKMS请款流程教授</p>
                </div>
                <div class="bg-indigo-50 rounded-xl p-4 border border-indigo-100">
                    <div class="flex items-center space-x-2 mb-2">
                        <i class="fas fa-tasks text-indigo-500"></i>
                        <span class="font-medium text-indigo-900">作业检查</span>
                    </div>
                    <p class="text-sm text-indigo-700">2769号土地成本测算检查</p>
                </div>
            </div>
        </div>

    </main>

    <!-- 作业提交模态框 -->
    <div id="homeworkModal" class="hidden fixed inset-0 bg-black/50 items-center justify-center z-50 backdrop-blur-sm">
        <div class="bg-white rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl transform transition-all scale-100">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-slate-800">提交作业</h3>
                <button onclick="closeHomeworkModal()" class="text-slate-400 hover:text-slate-600">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div class="mb-4">
                <p class="text-sm text-slate-600 mb-2">学员：<span id="modalStudentName" class="font-medium text-slate-800"></span></p>
                <div class="space-y-3">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">选择作业文件</label>
                        <div class="border-2 border-dashed border-slate-300 rounded-xl p-6 text-center hover:border-blue-400 transition-all cursor-pointer bg-slate-50" onclick="document.getElementById('fileInput').click()">
                            <i class="fas fa-cloud-upload-alt text-3xl text-slate-400 mb-2"></i>
                            <p class="text-sm text-slate-600">点击上传或拖拽文件至此</p>
                            <p class="text-xs text-slate-400 mt-1">支持 PDF、Excel、Word</p>
                            <input type="file" id="fileInput" class="hidden" accept=".pdf,.xlsx,.docx">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">备注说明</label>
                        <textarea id="homeworkNote" class="w-full border border-slate-300 rounded-lg p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" rows="3" placeholder="请输入作业完成情况或问题..."></textarea>
                    </div>
                </div>
            </div>
            <div class="flex space-x-3">
                <button onclick="closeHomeworkModal()" class="flex-1 px-4 py-2 border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 transition-all">取消</button>
                <button onclick="submitHomework()" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all shadow-lg shadow-blue-200">确认提交</button>
            </div>
        </div>
    </div>

    <script>
        // 培训数据配置
        const trainingData = {
            '2026-04-14': {
                title: '今日培训内容看板',
                subtitle: '2026年4月14日 · 法务助理入职培训 Day 1',
                tasks: [
                    { id: 1, title: '法务模块化内容学习', type: '理论学习', time: '09:00-10:30', desc: '学习今日法务模块化内容，掌握基础法务知识框架', tagColor: 'blue' },
                    { id: 2, title: '打印、扫描、文件发送', type: '实操技能', time: '10:45-12:00', desc: '学习打印机、扫描仪操作及文件发送流程', tagColor: 'indigo' },
                    { id: 3, title: '钉钉电子会议室预定', type: '系统操作', time: '13:30-14:30', desc: '熟悉钉钉系统中电子会议室的预定流程与管理', tagColor: 'purple' },
                    { id: 4, title: '开弈投资2779号、2769号大合同学习', type: '合同实务', time: '14:45-16:00', desc: '深入学习开弈投资两份重要合同的结构、条款与风险点', tagColor: 'amber' },
                    { id: 5, title: '用印文件登记', type: '流程实操', time: '16:15-17:00', desc: '学习用印文件用印后登记流程，完成各自的登记表', tagColor: 'rose' },
                    { id: 6, title: '合同类文件编号预习', type: '回课预习', time: '课后作业', desc: '预习合同类文件编号，明日回课', tagColor: 'amber', isReview: true },
                    { id: 7, title: '智名-成盈委托协议预习', type: '回课预习', time: '课后作业', desc: '预习智名-成盈委托协议，思考合同付款管理', tagColor: 'amber', isReview: true },
                    { id: 8, title: '2769号土地成本测算', type: '回课预习', time: '课后作业', desc: '完成2769号土地成本测算任务', tagColor: 'amber', isReview: true }
                ],
                zhao: { completed: 6, total: 8, tasks: [true, true, false, false, false, false, false, false] },
                qu: { completed: 4, total: 8, tasks: [true, false, false, false, false, false, false, false] },
                homework: [
                    { name: '用印登记表', zhao: 'completed', qu: 'pending' },
                    { name: '2769号土地成本测算', zhao: 'in-progress', qu: 'pending' }
                ]
            },
            '2026-04-15': {
                title: '今日培训内容看板',
                subtitle: '2026年4月15日 · 回课日与流程学习 Day 2',
                tasks: [
                    { id: 1, title: '合同编号规则回课', type: '回课检查', time: '09:00-10:00', desc: '检查合同类文件编号规则掌握情况', tagColor: 'emerald' },
                    { id: 2, title: 'HKMS请款流程教授', type: '新授内容', time: '10:15-12:00', desc: '学习HKMS系统请款流程操作', tagColor: 'blue' },
                    { id: 3, title: '2769号测算作业检查', type: '作业检查', time: '13:30-14:30', desc: '检查土地成本测算作业完成情况', tagColor: 'amber' },
                    { id: 4, title: '合同付款管理实务', type: '合同实务', time: '14:45-16:00', desc: '基于智名-成盈协议学习付款管理要点', tagColor: 'indigo' }
                ],
                zhao: { completed: 0, total: 4, tasks: [false, false, false, false] },
                qu: { completed: 0, total: 4, tasks: [false, false, false, false] },
                homework: [
                    { name: 'HKMS请款操作练习', zhao: 'pending', qu: 'pending' }
                ]
            }
        };

        let currentDate = '2026-04-14';
        let currentStudent = '';

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            loadDate(currentDate);
        });

        // 加载指定日期数据
        function loadDate(date) {
            currentDate = date;
            const data = trainingData[date];
            if (!data) return;

            // 更新标题
            document.getElementById('board-title').textContent = data.title;
            document.getElementById('board-subtitle').textContent = data.subtitle;
            document.getElementById('current-date').textContent = date.replace(/-/g, '年') + '日';
            document.getElementById('total-tasks').textContent = data.tasks.length;
            document.getElementById('review-tasks').textContent = data.tasks.filter(t => t.isReview).length;

            // 生成任务卡片
            renderTasks(data);

            // 更新进度
            updateDashboard('zhao', data.zhao);
            updateDashboard('qu', data.qu);

            // 更新作业列表
            renderHomework(data.homework);

            // 更新平均进度
            const avg = Math.round((data.zhao.completed + data.qu.completed) / (data.zhao.total + data.qu.total) * 100);
            document.getElementById('avg-progress').textContent = avg + '%';

            // 关闭日期面板
            document.getElementById('date-panel').classList.add('hidden');
        }

        // 渲染任务列表
        function renderTasks(data) {
            const container = document.getElementById('training-content');
            container.innerHTML = '';

            data.tasks.forEach((task, index) => {
                const isReview = task.isReview;
                const cardClass = isReview ? 'bg-gradient-to-br from-amber-50 to-orange-50 border-amber-200' : 'border-slate-100';
                
                const html = `
                    <div class="glass-panel rounded-2xl p-6 shadow-sm card-hover border ${cardClass}">
                        <div class="flex items-start justify-between mb-4">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 rounded-full bg-${task.tagColor}-100 flex items-center justify-center text-${task.tagColor}-600 font-bold">
                                    ${isReview ? '<i class="fas fa-book-reader"></i>' : task.id}
                                </div>
                                <div>
                                    <h3 class="font-bold text-slate-800">${task.title}</h3>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-${task.tagColor}-100 text-${task.tagColor}-800 mt-1">
                                        ${task.type}
                                    </span>
                                </div>
                            </div>
                            <span class="text-xs ${isReview ? 'text-amber-600 font-medium' : 'text-slate-400'}">${task.time}</span>
                        </div>
                        <p class="text-sm text-slate-600 mb-4">${task.desc}</p>
                        
                        <div class="space-y-3 bg-white/60 rounded-xl p-4">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-2">
                                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-400 to-rose-500 flex items-center justify-center text-white text-xs font-bold">赵</div>
                                    <span class="text-sm font-medium text-slate-700">赵柳文</span>
                                </div>
                                <label class="flex items-center cursor-pointer">
                                    <input type="checkbox" class="task-checkbox hidden" ${data.zhao.tasks[index] ? 'checked' : ''} 
                                        onchange="updateProgress(this, 'zhao', ${index})">
                                    <div class="w-6 h-6 rounded-md border-2 border-slate-300 flex items-center justify-center transition-all">
                                        <i class="fas fa-check text-white text-xs opacity-0 transform scale-0 transition-all"></i>
                                    </div>
                                    <span class="ml-2 text-xs ${data.zhao.tasks[index] ? 'text-emerald-600' : 'text-slate-400'} font-medium status-text">
                                        ${data.zhao.tasks[index] ? '已完成' : '进行中'}
                                    </span>
                                </label>
                            </div>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-2">
                                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-white text-xs font-bold">曲</div>
                                    <span class="text-sm font-medium text-slate-700">曲源</span>
                                </div>
                                <label class="flex items-center cursor-pointer">
                                    <input type="checkbox" class="task-checkbox hidden" ${data.qu.tasks[index] ? 'checked' : ''} 
                                        onchange="updateProgress(this, 'qu', ${index})">
                                    <div class="w-6 h-6 rounded-md border-2 border-slate-300 flex items-center justify-center transition-all">
                                        <i class="fas fa-check text-white text-xs opacity-0 transform scale-0 transition-all"></i>
                                    </div>
                                    <span class="ml-2 text-xs ${data.qu.tasks[index] ? 'text-emerald-600' : 'text-slate-400'} font-medium status-text">
                                        ${data.qu.tasks[index] ? '已完成' : '进行中'}
                                    </span>
                                </label>
                            </div>
                        </div>
                    </div>
                `;
                container.innerHTML += html;
            });
        }

        // 渲染作业列表
        function renderHomework(homework) {
            const zhaoContainer = document.getElementById('zhao-homework');
            const quContainer = document.getElementById('qu-homework');
            
            zhaoContainer.innerHTML = '';
            quContainer.innerHTML = '';

            homework.forEach(hw => {
                const zhaoStatus = getStatusBadge(hw.zhao);
                const quStatus = getStatusBadge(hw.qu);
                
                zhaoContainer.innerHTML += `
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                        <div class="flex items-center space-x-2">
                            <i class="fas fa-file-alt text-slate-400"></i>
                            <span class="text-sm text-slate-700">${hw.name}</span>
                        </div>
                        ${zhaoStatus}
                    </div>
                `;
                
                quContainer.innerHTML += `
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                        <div class="flex items-center space-x-2">
                            <i class="fas fa-file-alt text-slate-400"></i>
                            <span class="text-sm text-slate-700">${hw.name}</span>
                        </div>
                        ${quStatus}
                    </div>
                `;
            });

            // 添加提交按钮
            zhaoContainer.innerHTML += `
                <button onclick="openHomeworkModal('赵柳文')" class="w-full mt-2 text-xs bg-white border border-slate-300 px-3 py-2 rounded-lg hover:bg-slate-50 transition-all flex items-center justify-center">
                    <i class="fas fa-upload mr-1"></i>提交新作业
                </button>
            `;
            quContainer.innerHTML += `
                <button onclick="openHomeworkModal('曲源')" class="w-full mt-2 text-xs bg-white border border-slate-300 px-3 py-2 rounded-lg hover:bg-slate-50 transition-all flex items-center justify-center">
                    <i class="fas fa-upload mr-1"></i>提交新作业
                </button>
            `;
        }

        function getStatusBadge(status) {
            const badges = {
                'completed': '<span class="text-xs px-2 py-1 bg-emerald-100 text-emerald-700 rounded-full">已完成</span>',
                'in-progress': '<span class="text-xs px-2 py-1 bg-amber-100 text-amber-700 rounded-full">进行中</span>',
                'pending': '<span class="text-xs px-2 py-1 bg-slate-200 text-slate-600 rounded-full">未开始</span>'
            };
            return badges[status] || badges['pending'];
        }

        // 更新进度
        function updateProgress(checkbox, person, taskIndex) {
            const data = trainingData[currentDate];
            const isChecked = checkbox.checked;
            const statusText = checkbox.parentElement.querySelector('.status-text');
            
            if (isChecked) {
                statusText.textContent = '已完成';
                statusText.className = 'ml-2 text-xs text-emerald-600 font-medium status-text';
                data[person].completed++;
                data[person].tasks[taskIndex] = true;
            } else {
                statusText.textContent = '进行中';
                statusText.className = 'ml-2 text-xs text-slate-400 font-medium status-text';
                data[person].completed--;
                data[person].tasks[taskIndex] = false;
            }
            
            updateDashboard(person, data[person]);
            
            // 更新平均进度
            const avg = Math.round((data.zhao.completed + data.qu.completed) / (data.zhao.total + data.qu.total) * 100);
            document.getElementById('avg-progress').textContent = avg + '%';
        }

        // 更新仪表盘
        function updateDashboard(person, data) {
            const percentage = Math.round((data.completed / data.total) * 100);
            const circumference = 2 * Math.PI * 45;
            const offset = circumference - (percentage / 100) * circumference;
            
            document.getElementById(`${person}-progress`).style.strokeDashoffset = offset;
            document.getElementById(`${person}-percent`).textContent = percentage + '%';
            document.getElementById(`${person}-count`).textContent = `${data.completed}/${data.total}`;
            document.getElementById(`${person}-bar`).style.width = percentage + '%';
        }

        // 切换视图
        function switchView(view) {
            const content = document.getElementById('training-content');
            const btnList = document.getElementById('btn-list');
            const btnCard = document.getElementById('btn-card');
            
            if (view === 'list') {
                content.classList.remove('lg:grid-cols-2');
                content.classList.add('grid-cols-1');
                btnList.className = 'px-4 py-2 rounded-lg bg-white shadow-sm text-blue-600 border border-blue-200';
                btnCard.className = 'px-4 py-2 rounded-lg bg-white shadow-sm text-slate-600 hover:bg-slate-50 transition-all';
            } else {
                content.classList.remove('grid-cols-1');
                content.classList.add('grid-cols-1', 'lg:grid-cols-2');
                btnCard.className = 'px-4 py-2 rounded-lg bg-white shadow-sm text-blue-600 border border-blue-200';
                btnList.className = 'px-4 py-2 rounded-lg bg-white shadow-sm text-slate-600 hover:bg-slate-50 transition-all';
            }
        }

        // 切换日期面板
        function switchDate() {
            const panel = document.getElementById('date-panel');
            panel.classList.toggle('hidden');
        }

        // 打开作业模态框
        function openHomeworkModal(studentName) {
            currentStudent = studentName;
            document.getElementById('modalStudentName').textContent = studentName;
            document.getElementById('homeworkModal').classList.remove('hidden');
            document.getElementById('homeworkModal').classList.add('flex');
        }

        // 关闭作业模态框
        function closeHomeworkModal() {
            document.getElementById('homeworkModal').classList.add('hidden');
            document.getElementById('homeworkModal').classList.remove('flex');
            document.getElementById('fileInput').value = '';
            document.getElementById('homeworkNote').value = '';
        }

        // 提交作业
        function submitHomework() {
            closeHomeworkModal();
            
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-4 right-4 bg-emerald-500 text-white px-6 py-3 rounded-lg shadow-lg transform transition-all duration-300 z-50 flex items-center';
            toast.innerHTML = '<i class="fas fa-check-circle mr-2"></i><div><p class="font-medium">作业提交成功！</p><p class="text-xs text-emerald-100">' + currentStudent + '的作业已保存</p></div>';
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.transform = 'translateY(100px)';
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // 点击外部关闭
        document.getElementById('homeworkModal').addEventListener('click', (e) => {
            if (e.target === document.getElementById('homeworkModal')) {
                closeHomeworkModal();
            }
        });

        // 文件选择监听
        document.getElementById('fileInput').addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                const fileName = e.target.files[0].name;
                const uploadArea = e.target.parentElement;
                uploadArea.innerHTML = `
                    <i class="fas fa-file-alt text-3xl text-blue-500 mb-2"></i>
                    <p class="text-sm text-slate-700 font-medium">${fileName}</p>
                    <p class="text-xs text-slate-400 mt-1">点击更换文件</p>
                    <input type="file" id="fileInput" class="hidden" accept=".pdf,.xlsx,.docx">
                `;
                // 重新绑定事件
                uploadArea.onclick = () => document.getElementById('fileInput').click();
                document.getElementById('fileInput').addEventListener('change', arguments.callee);
            }
        });
    </script>
</body>
</html>
